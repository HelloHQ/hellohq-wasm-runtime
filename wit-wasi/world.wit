// Vendored wasi:http@0.3.0-rc world for the Option B outbound-HTTP host. The
// plugin imports wasi:http/handler and calls handle(request) for outbound
// fetches; the host implements handle, routed app-side (gated) via P3.
package hellohq:http-probe;

world http-probe {
  import wasi:http/handler@0.3.0-rc-2026-01-06;
}

// Guest-side world for the STAGE 3 end-to-end test. A guest built against this
// imports wasi:http/{types,handler} — it constructs a request (GET example.com/),
// calls handler.handle, reads the response status + body — and exports `run`
// returning the body bytes so the host test can assert the synthesized echo
// ("GET example.com/"). The guest pulls in wasi:clocks/types transitively (the
// `duration` used by request-options); the host satisfies it (empty Host impl).
world http-guest {
  import wasi:http/types@0.3.0-rc-2026-01-06;
  import wasi:http/handler@0.3.0-rc-2026-01-06;
  // `run` is `async func` because the guest awaits the async `handler.handle`
  // import and drains the response body stream — both yield, so the export task
  // must be async (a sync export traps with "cannot block a synchronous task").
  export run: async func() -> list<u8>;
}

// Guest-side world for the streaming-REQUEST-body (POST) test. Identical surface
// to `http-guest`, but the guest constructs a POST request carrying a body
// `stream<u8>` (writing "req-body-123"), calls handler.handle, and returns the
// response status + body. Proves the host reads the guest's request-body stream
// and emits it as OUT frames before ending the outbound stream.
world http-guest-post {
  import wasi:http/types@0.3.0-rc-2026-01-06;
  import wasi:http/handler@0.3.0-rc-2026-01-06;
  export run: async func() -> list<u8>;
}

// Guest-side world for the request-TRAILERS test. Identical surface to
// `http-guest-post`, but the guest constructs a GET request whose request
// trailers future resolves to `Ok(Some(fields))` carrying `x-trace` =
// "req-trailer-1". Proves the host drains the request trailers future and
// surfaces it OUT on the head as a reserved `x-hellohq-request-trailers` line.
world http-guest-req-trailers {
  import wasi:http/types@0.3.0-rc-2026-01-06;
  import wasi:http/handler@0.3.0-rc-2026-01-06;
  export run: async func() -> list<u8>;
}
